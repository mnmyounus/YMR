<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">
    <ImageView android:id="@+id/ivCallType" android:layout_width="24dp" android:layout_height="24dp"
        android:layout_marginEnd="12dp" android:src="@drawable/ic_phone_in"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="15sp" android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>
        <TextView android:id="@+id/tvNumber" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>
    </LinearLayout>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/tvDate" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>
        <TextView android:id="@+id/tvDuration" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>
    </LinearLayout>
</LinearLayout>
